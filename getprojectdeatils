import json
import os
import time
import requests
import constants

# 1. Configuration
URL = constants.API_URL
OUTPUT_FILE = "sync_results.json"


SYNC_RESULTS_FILE = "sync_results.json"

def get_project_ids_from_sync_results(filename=SYNC_RESULTS_FILE):
    """Extracts projectId list from sync_results.json file."""
    with open(filename, "r") as f:
        data = json.load(f)
    return [item["projectId"] for item in data if "projectId" in item]

HEADERS = {
    "Content-Type": "application/json",
    "Authorization": constants.API_TOKEN
}

# 2. GraphQL Project Details Query
PROJECT_DETAILS_QUERY = """
query GetProjectByID($getProjectId: Int!) {
  getProject(id: $getProjectId) {
    engineeringManagerEmail
  }
}
"""

def save_to_json_file(new_record, filename=OUTPUT_FILE):
    """Safely loads, appends, and updates the local JSON file."""
    file_data = []
    if os.path.exists(filename) and os.path.getsize(filename) > 0:
        with open(filename, "r") as file:
            try:
                file_data = json.load(file)
            except json.JSONDecodeError:
                file_data = []
                
    file_data.append(new_record)
    with open(filename, "w") as file:
        json.dump(file_data, file, indent=4)


def fetch_project_details():
    project_ids = get_project_ids_from_sync_results()
    print(f"🚀 Fetching project details for {len(project_ids)} projects...\n")

    results = []
    for project_id in project_ids:
        print(f"🔄 Fetching details for Project ID: {project_id}...")

        payload = {
            "query": PROJECT_DETAILS_QUERY,
            "variables": {"getProjectId": project_id}
        }

        try:
            response = requests.post(URL, json=payload, headers=HEADERS)
            response.raise_for_status()
            response_data = response.json()

            if "errors" in response_data:
                print(f"❌ GraphQL Error for ID {project_id}: {response_data['errors']}")
                results.append({"projectId": project_id, "error": response_data["errors"]})
            else:
                project_obj = response_data["data"]["getProject"]
                if project_obj:
                    em_email = project_obj.get("engineeringManagerEmail")
                    print(f"📧 Found EM Email: {em_email}")
                    log_entry = {
                        "projectId": project_id,
                        "engineeringManagerEmail": em_email,
                        "timestamp": time.strftime("%Y-%m-%d %H:%M:%S")
                    }
                    results.append(log_entry)
                else:
                    print(f"⚠️ No project data returned for ID {project_id}")
                    results.append({"projectId": project_id, "error": "No project data returned"})

        except requests.exceptions.RequestException as e:
            print(f"💥 HTTP Request failed for ID {project_id}: {e}")
            results.append({"projectId": project_id, "error": str(e)})

        time.sleep(1)
        print()

    with open("engineering_emails.json", "w") as f:
        json.dump(results, f, indent=4)
    print(f"🏁 Execution finished. Output saved to engineering_emails.json.")

if __name__ == "__main__":
    fetch_project_details()